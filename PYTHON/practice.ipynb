    "def rever(x):\n",
    "    x = str(x);\n",
    "    y = list(x)\n",
    "    z = []\n",
    "    n = len(y)\n",
    "    for i in range(n):\n",
    "        z.append(y[- i])\n",
    "    return z\n",
    "\n",
    "rever(123)\n",
